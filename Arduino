void drawBmp(const char *filename, int x, int y, int w, int h, bool toSprite = false) {
  File bmpFile = SD.open(filename);
  if (!bmpFile) return;
  bmpFile.seek(54);

  int rowSizeRaw = w * 3;
  int rowSizePadded = (rowSizeRaw + 3) & ~3;
  int padding = rowSizePadded - rowSizeRaw;
  uint8_t lineBuffer[rowSizeRaw];

  for (int i = h - 1; i >= 0; i--) {
    bmpFile.read(lineBuffer, sizeof(lineBuffer));
    for (int j = 0; j < w; j++) {
      uint16_t color = tft.color565(lineBuffer[j * 3 + 2], lineBuffer[j * 3 + 1], lineBuffer[j * 3]);

      if (toSprite) {
        // 如果 toSprite 是 true，就畫進 Sprite (雙緩衝平滑更新)
        spr.drawPixel(x + j, y + i, color);
      } else {
        // 如果是 false，直接畫在螢幕 (setup 初始化用)
        tft.drawPixel(x + j, y + i, color);
      }
    }
    if (padding > 0) bmpFile.seek(bmpFile.position() + padding);
  }
  bmpFile.close();
}

void drawBmpToSprite(const char *filename, int x, int y, int w, int h) {
  File bmpFile = SD.open(filename);
  if (!bmpFile) return;
  bmpFile.seek(54);

  int rowSizeRaw = w * 3;
  int rowSizePadded = (rowSizeRaw + 3) & ~3;
  int padding = rowSizePadded - rowSizeRaw;
  uint8_t lineBuffer[rowSizeRaw];

  for (int i = h - 1; i >= 0; i--) {
    bmpFile.read(lineBuffer, sizeof(lineBuffer));
    for (int j = 0; j < w; j++) {
      uint16_t color = tft.color565(lineBuffer[j * 3 + 2], lineBuffer[j * 3 + 1], lineBuffer[j * 3]);
      // 這裡改用 spr.drawPixel，畫在記憶體裡，使用者看不到
      spr.drawPixel(x + j, y + i, color);
    }
    if (padding > 0) bmpFile.seek(bmpFile.position() + padding);
  }
  bmpFile.close();
}

void refreshLeftArea() {
  static int maxT = 0, minT = 0, lastIconId = 51;
  static float currentT = 0;

  // --- 1. 抓取即時數據 (rhrread)：獲取實時圖示 & 黃大仙溫度 ---
  // 1. 抓取即時數據 (rhrread)
  {
    HTTPClient http;
    http.begin("https://data.weather.gov.hk/weatherAPI/opendata/weather.php?dataType=rhrread&lang=tc");
    int httpCode = http.GET();
    if (httpCode == HTTP_CODE_OK) {
      String payload = http.getString();

      // 先確認地點是否存在
      int tempSectionPos = payload.indexOf("\"temperature\":");  // 先定位到溫度區塊
      if (tempSectionPos != -1) {
        int pos = payload.indexOf(savedWeatherLocation, tempSectionPos);  // 由溫度區塊開始搵黃大仙
        if (pos != -1) {
          int valPos = payload.indexOf("\"value\":", pos);
          if (valPos != -1) {
            int start = valPos + 8;
            int end = payload.indexOf(",", start);

            // 提取並轉換
            String tempStr = payload.substring(start, end);
            currentT = tempStr.toFloat();

            Serial.print("Parsed Temp: ");
            Serial.println(currentT);
          }
        }
      }

      // 抓實時圖示 (保持不變)
      int iconPos = payload.indexOf("\"icon\":[");
      if (iconPos != -1) {
        int start = iconPos + 8;
        lastIconId = payload.substring(start, payload.indexOf("]", start)).toInt();
      }
    }
    http.end();
  }

  // --- 2. 抓取預報數據 (fnd)：獲取今日最高/最低溫 ---
  {
    HTTPClient http;
    http.begin("https://data.weather.gov.hk/weatherAPI/opendata/weather.php?dataType=fnd&lang=tc");
    int httpCode = http.GET();
    if (httpCode == HTTP_CODE_OK) {
      String payload = http.getString();

      // 尋找最高溫 (forecastMaxtemp - 注意 API 是小寫 t)
      int maxPos = payload.indexOf("forecastMaxtemp");
      if (maxPos != -1) {
        int valPos = payload.indexOf("\"value\":", maxPos);
        if (valPos != -1) {
          maxT = payload.substring(valPos + 8, payload.indexOf(",", valPos + 8)).toInt();
        }
      }

      // 尋找最低溫 (forecastMintemp - 注意 API 是小寫 t)
      int minPos = payload.indexOf("forecastMintemp");
      if (minPos != -1) {
        int valPos = payload.indexOf("\"value\":", minPos);
        if (valPos != -1) {
          minT = payload.substring(valPos + 8, payload.indexOf(",", valPos + 8)).toInt();
        }
      }
      Serial.printf("Forecast Update: Max %d, Min %d\n", maxT, minT);
    } else {
      Serial.printf("FND HTTP Failed: %d\n", httpCode);
    }
    http.end();
  }

  // --- 第三階段：獲取時間並開始繪圖 ---
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) return;

  if (spr.createSprite(166, 240)) {
    // 1. 背景邏輯 (包含 night_cloud)
    String bgFile;
    bool isDay = (timeinfo.tm_hour >= 7 && timeinfo.tm_hour < 19);
    if (lastIconId >= 60 && lastIconId <= 65) {
      bgFile = isDay ? "/cloud.bmp" : "/night_cloud.bmp";
    } else {
      bgFile = isDay ? "/day.bmp" : "/night.bmp";
    }
    drawBmp(bgFile.c_str(), 0, 0, 166, 240, true);

    // 3. 畫日期 (你的原本代碼：年份、月份偏移、日期偏移)
    spr.loadFont("test_12", SD);
    spr.setTextColor(TFT_WHITE);
    // 年份 (43)
    spr.drawNumber(timeinfo.tm_year + 1900, 36, 67);
    spr.drawNumber(timeinfo.tm_year + 1900, 37, 67);
    // 月份 (83)
    // --- 繪製月份 ---
    int mon = timeinfo.tm_mon + 1;  // 獲取實際月份 (0-11 轉為 1-12)

    // 如果月份小於 10 (即 1-9 月)，x 設為 81；否則 (10-12 月) x 設為 78
    int monX = (mon < 10) ? 81 : 78;

    spr.drawNumber(mon, monX, 67);
    spr.drawNumber(mon, monX + 1, 67);  // 加粗

    // 日期 (108)
    int day = timeinfo.tm_mday;
    int dayX = (day < 10) ? 108 : 105;  // 如果是 10 號以後，向左移 3 像素
    spr.drawNumber(day, dayX, 67);
    spr.drawNumber(day, dayX + 1, 67);

    spr.unloadFont();

    spr.setTextDatum(MC_DATUM);
    int centerX = 166 / 2;  // 83

    // 2. 畫時間 (test_26) @ 48, 29
    spr.setTextColor(TFT_WHITE);
    spr.loadFont("test_26", SD);
    char timeStr[6];
    sprintf(timeStr, "%02d:%02d", timeinfo.tm_hour, timeinfo.tm_min);
    spr.drawString(timeStr, centerX, 45);
    spr.drawString(timeStr, centerX + 1, 45);  // 加粗
    spr.unloadFont();

    // 4. 畫當前溫度 (test_45) @ 54, 114
    spr.loadFont("test_45", SD);
    String numPart = String((int)currentT);
    spr.drawString(numPart, centerX, 138);
    spr.drawString(numPart, centerX + 1, 138);  // 加粗

    // 2. 計算數字佔用的寬度，以便定位符號
    int numWidth = spr.textWidth(numPart);
    // 3. 把基準點改回左上角，把 ° 畫在數字右側
    spr.setTextDatum(TL_DATUM);
    // 計算符號的 X 位置：中心點 + 數字一半的寬度 + 5像素空隙
    int degreeX = centerX + (numWidth / 2) + 3;
    // 符號的 Y 通常要比數字高一點點，你可以微調這個 5
    spr.drawString("°", degreeX, 113);
    spr.unloadFont();

    // 5. 畫最高/最低溫 (test_28)
    spr.loadFont("test_32", SD);
    // 最高溫 @ 35, 162
    String maxStr = String(maxT) + "°";
    spr.drawString(maxStr, 32, 163);
    spr.drawString(maxStr, 33, 163);
    // 最低溫 @ 119, 162
    String minStr = String(minT) + "°";
    spr.drawString(minStr, 103, 163);
    spr.drawString(minStr, 104, 163);
    spr.unloadFont();


    // 6. 推送並釋放
    spr.pushSprite(0, 0);
    spr.deleteSprite();
  }
}

