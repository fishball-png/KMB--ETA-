void handleSave() {
  // 1. 開啟 Preferences
  prefs.begin("KMB-ETA", false);

  // 2. 儲存地點
  if (server.hasArg("weatherLocData")) {
    String newLoc = server.arg("weatherLocData");
    savedWeatherLocation = newLoc;  // 更新記憶體變數
    prefs.putString("location", newLoc);
    Serial.println("Writing to Flash: " + newLoc);
  }

  // 3. 儲存巴士清單
  if (server.hasArg("fullData")) {
    savedDataJSON = server.arg("fullData");
    prefs.putString("data", savedDataJSON);
  }

  // 4. 強制寫入並關閉 (非常重要)
  // Preferences 在寫入字串時是異步的，延遲一下確保數據安全存入 Flash
  delay(100);
  prefs.end();

  // 5. 先回傳網頁訊息給瀏覽器，讓網頁不要 Lag
  String msg = "<html><meta charset='UTF-8'><body>儲存成功！地點已設為：" + savedWeatherLocation + "，正在重啟...</body>";
  msg += "<script>setTimeout(()=>location.href='/', 3000)</script></html>";
  server.send(200, "text/html", msg);

  // 6. 給 ESP32 充足時間發送完網路封包後再重啟
  Serial.println("Save complete. Restarting in 2 seconds...");
  delay(2000);
  ESP.restart();
}

void handleResetWifi() {
  server.send(200, "text/html; charset=UTF-8", "WiFi 已重置，正在進入 AP 模式...");
  WiFiManager wm;
  wm.resetSettings();
  ESP.restart();
}

