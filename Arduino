void updateBusRow(int row, String route, String etaMin, String dest_tc) {
  if (row > 3) return;
  int yOffset = 40 + (row * 47);
  uint16_t rowBgColor = (row == 0 || row == 2) ? TFT_WHITE : tft.color565(250, 240, 255);

  if (!spr.createSprite(154, 47)) return;
  spr.fillSprite(rowBgColor);

  spr.setTextColor(tft.color565(57, 62, 68));
  spr.loadFont("test_8", SD);
  spr.drawString(route, 5, 4);
  spr.unloadFont();


  if (SD.exists("/test_3.vlw")) {
    spr.loadFont("test_3", SD);
    spr.drawString("往 " + dest_tc, 5, 32);
    spr.unloadFont();
  }

  if (etaMin == "!") {
    spr.drawSmoothCircle(137, 17, 12, tft.color565(41, 102, 163), rowBgColor);
    spr.setTextColor(tft.color565(41, 102, 163));
    spr.loadFont("test_16", SD);
    spr.drawString("!", 136, 10);
    spr.unloadFont();
  } else {
    spr.setTextDatum(TR_DATUM);
    spr.setTextColor(tft.color565(41, 102, 163));
    spr.loadFont("test_8", SD);
    String displayStr = (etaMin == "0") ? "-" : etaMin;
    // 邏輯：如果是 "-" 設為 139；如果長度是 1 (1-9) 設為 144；否則 (10+) 設為 149
int xPos = (displayStr == "-") ? 141 : (displayStr.length() == 1 ? 144 : 149);
    spr.drawString(displayStr, xPos, 4);
    spr.setTextDatum(TL_DATUM);
    spr.unloadFont();
  }

  spr.pushSprite(166, yOffset - 4);
  spr.deleteSprite();
}

// --- 4. 數據抓取 ---
void fetchMultiKMBData() {
  if (WiFi.status() == WL_CONNECTED && savedDataJSON.length() > 5) {
    struct tm timeinfo;
    if (!getLocalTime(&timeinfo)) return;
    time_t now;
    time(&now);

    DynamicJsonDocument configDoc(1024);
    deserializeJson(configDoc, savedDataJSON);
    JsonArray array = configDoc.as<JsonArray>();

    int rowIndex = 0;
    for (JsonObject obj : array) {
      if (rowIndex >= 4) break;
      String r = obj["r"].as<String>();
      String sid = obj["sid"].as<String>();
      HTTPClient http;
      http.begin("https://data.etabus.gov.hk/v1/transport/kmb/stop-eta/" + sid);

      if (http.GET() == 200) {
        DynamicJsonDocument etaDoc(20480);
        deserializeJson(etaDoc, http.getStream());
        bool found = false;
        for (JsonObject bus : etaDoc["data"].as<JsonArray>()) {
          if (bus["route"].as<String>() == r) {
            String dest = bus["dest_tc"].as<String>();
            if (bus["eta"].isNull()) {
              updateBusRow(rowIndex, r, "!", dest);
              found = true;
              break;
            }
            const char *etaChar = bus["eta"];
            if (etaChar && strlen(etaChar) >= 19) {
              String etaStr = String(etaChar);
              struct tm etaTm = { 0 };
              etaTm.tm_year = etaStr.substring(0, 4).toInt() - 1900;
              etaTm.tm_mon = etaStr.substring(5, 7).toInt() - 1;
              etaTm.tm_mday = etaStr.substring(8, 10).toInt();
              etaTm.tm_hour = etaStr.substring(11, 13).toInt();
              etaTm.tm_min = etaStr.substring(14, 16).toInt();
              etaTm.tm_sec = etaStr.substring(17, 19).toInt();
              time_t busTime = mktime(&etaTm);
              int diffMin = (int)(difftime(busTime, now) / 60);

              if (diffMin <= 0) updateBusRow(rowIndex, r, "0", dest);
              else updateBusRow(rowIndex, r, String(diffMin), dest);
              found = true;
              break;
            }
          }
        }
        if (!found) updateBusRow(rowIndex, r, "!", "N/A");
      }
      http.end();
      rowIndex++;
      delay(150);
    }
  }
}

void setup() {
  Serial.begin(115200);
  tft.init();
  tft.setRotation(1);
  pinMode(21, OUTPUT);
  analogWrite(21, 128);
  digitalWrite(21, HIGH);

  // --- SD 卡檢查區塊 ---
  if (!SD.begin(SD_CS)) {
    Serial.println("SD Fail");
    while (1)
      ;  // 如果 SD 失敗就停在這裡
  }
  // --- SD 檢查結束 ---

  // 這裡才是正確的位置！不管 SD 卡成不成功，都要讀取設定
  prefs.begin("KMB-ETA", true);
  savedWeatherLocation = prefs.getString("location", "黃大仙");
  savedDataJSON = prefs.getString("data", "[]");
  prefs.end();

  Serial.println("--- Startup Check ---");
  Serial.print("Location from Flash: ");
  Serial.println(savedWeatherLocation);

  WiFiManager wm;
  wm.autoConnect("ESP32 Wifi");

  server.on("/set_brightness", []() {
  if (server.hasArg("v")) {
    int brightness = server.arg("v").toInt();
    analogWrite(21, brightness);
    // 可選：存入 Preferences 永久記住亮度
    prefs.begin("KMB-ETA", false);
    prefs.putInt("brt", brightness);
    prefs.end();
  }
  server.send(200);
});

  if (MDNS.begin("KMB-ETA")) {
    Serial.println("MDNS: http://KMB-ETA.local");
  }

  configTime(28800, 0, "pool.ntp.org", "stdtime.gov.hk");

  prefs.begin("KMB-ETA", false);
  savedDataJSON = prefs.getString("data", "[]");
  prefs.end();

  server.on("/", handleRoot);
  server.on("/save", HTTP_POST, handleSave);
  server.on("/reset_wifi", handleResetWifi);
  server.begin();

  drawBmp("/kmb.bmp", 0, 0, 320, 240);  // 畫全屏底圖
  refreshLeftArea();                    // 覆蓋左側日夜圖
  fetchMultiKMBData();
}

void loop() {
  server.handleClient();
  unsigned long now = millis();

  // 每 30 秒檢查一次日夜狀態並刷新左側
  static unsigned long lastLeftUpdate = 0;
  if (now - lastLeftUpdate > 5000) {
    refreshLeftArea();
    lastLeftUpdate = now;
  }

  // 巴士數據更新 (每 5 秒)
  static unsigned long lastBusUpdate = 0;
  if (now - lastBusUpdate > 5000) {
    fetchMultiKMBData();
    lastBusUpdate = now;
  }
}
